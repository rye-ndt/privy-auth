VITE_PRIVY_APP_ID=your-privy-app-id-here
VITE_BACKEND_URL=https://your-backend-url/api
VITE_CHAIN_ID=43114
VITE_CHAIN_RPC_URL=https://api.pimlico.io/v2/43114/rpc?apikey=your-pimlico-api-key
# Bundler RPCs go through the BE proxy (see be/constructions/2026-05-15-bundler-proxy-be.md).
# The FE no longer holds a pimlico bundler API key — VITE_BACKEND_URL above is
# the origin and the per-chain bundler URL is computed as
# `${VITE_BACKEND_URL}/aa/bundler/<chainId>`. Paymaster URLs stay direct to pimlico.
VITE_PIMLICO_PAYMASTER_URL=https://api.pimlico.io/v2/43114/rpc?apikey=your-pimlico-api-key
# Pimlico sponsorship policy ID (from dashboard). Without this, the paymaster
# applies the project default policy and may reject all UserOps.
VITE_PIMLICO_SPONSORSHIP_POLICY_ID=sp_your_policy_id
# BSC (chain 56) — required for Aster tokenized stocks. If the bundler URL is
# absent at runtime, createSessionKeyClient(56) / createSudoClient(56) throw a
# clean "BSC chain is not configured in this build" error.
VITE_BSC_RPC_URL=https://bsc.publicnode.com
VITE_BSC_PIMLICO_PAYMASTER_URL=
VITE_BSC_PIMLICO_SPONSORSHIP_POLICY_ID=
VITE_LOG_LEVEL=info
